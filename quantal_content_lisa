#%% modeling the two docking sites

import numpy as np
from matplotlib.pyplot import plot as pt
import matplotlib.pyplot as plt
from numpy.random import exponential, binomial, gamma
from numpy import exp
from numpy import sqrt as Sqrt
from numpy import log as Log



def sim2(n, ni, f, pr, pri, M, Mi, k, ki, tauc, ca, c, cb, tmax, delta_t, navgs):
    
    navs=[]
    niavs=[]
    bavs=[]
    biavs=[]
    
    for _ in range(navgs):
    
        nlist=[]
        blist=[]
        bilist=[]
        calist=[cb]
        nilist=[]
        tlist=[]
        prelist=[]
        
        tcurr=0
        ratio = 0.3
        timer = delta_t
        bnum=0
        e=1e-6
        while tcurr < tmax:
            t0=exponential(1/(f+e)) # action potential
            t1=exponential(1/(k*(M-n)+e)) # site gets occupied
            t2=exponential(1/(ki*(Mi-ni)+e)) # site gets occupied
            t3 = timer
    
            if t0 < t1 and t0 < t2 and t0<t3: # AP occurrs
                b = binomial(n, pr)
                n-=b
                blist.append(b)
                bi = binomial(ni, pri)
                ni-=bi
                bilist.append(bi)
                ca+=c
                tmin = t0
                timer-=tmin
                prelist.append(tcurr+tmin)
                bnum+=1
    
            elif t1<t0 and t1<t2 and t1<t3: # add a docked vesicle
                n+=1
                tmin = t1
                timer-=tmin
    
            elif t2<t0 and t2<t1 and t2<t3: # add a docked vesicle
                ni+=1
                tmin = t3
                timer-=tmin
    
            else:
                tmin=t3
                timer = delta_t
                if tcurr >= ratio*tmax:
                    nlist.append(n)
                    nilist.append(ni)
                    tlist.append(tcurr)
                    calist.append(ca)
                    
            tcurr += tmin
            # Update the calcium dynamics
            ca += -(ca-cb)/tauc*tmin
        bavs.append(blist)
        biavs.append(bilist)
    
    return tlist, nlist, nilist, bavs, biavs, prelist

def sim(n, f, pr, M, k, tauc, ca, c, cb, tmax, delta_t, navgs):
    
    navs=[]
    bavs=[]
    
    for _ in range(navgs):
    
        nlist=[]
        blist=[]
        calist=[]
        tlist=[]
        prelist=[]
        
        tcurr=0
        ratio = 0#.3
        timer = delta_t
        bnum=0
        e=1e-6
        while tcurr < tmax:
            t0=exponential(1/(f+e)) # action potential
            t1=exponential(1/(k*(M-n)+e)) # site gets occupied
            t2 = timer
    
            if t0 < t1 and t0 < t2: # AP occurrs
                b = binomial(n, pr)
                n-=b
                blist.append(b)
                ca+=c
                tmin = t0
                timer-=tmin
                prelist.append(tcurr+tmin)
                bnum+=1
    
            elif t1<t0 and t1<t2: # add a docked vesicle
                n+=1
                tmin = t1
                timer-=tmin
    
    
            else:
                tmin=t2
                timer = delta_t
                if tcurr >= ratio*tmax:
                    nlist.append(n)
                    tlist.append(tcurr)
                    calist.append(ca)
                    
            tcurr += tmin
            # Update the calcium dynamics
            ca += -(ca-cb)/tauc*tmin
        bavs.append(blist)
        
            
    minlen = np.min([len(x) for x in bavs])
    bavs = np.array([x[:minlen] for x in bavs])
    bavs=np.mean(bavs, axis=0)
    
    return tlist, nlist, bavs, prelist, calist

