    dCafdt=kin[i-1]-kbind*Caf[i-1]*(M-Cab[i-1])+kunbind*Cab[i-1]-klost*Caf[i-1]
    dCabdt=kbind*Caf[i-1]*(M-Cab[i-1])-kunbind*Cab[i-1]
    
    Caf[i]=Caf[i-1]+dCafdt*dt
    Cab[i]=Cab[i-1]+dCabdt*dt

