#%% calcium dynamics

kbind=10 # rate of calcium binding to buffer
kunbind=100 # rate of calcium unbinding from buffer
klost=10 # rate of calcium lost to cell
M=20 # buffer capacity


kinbar=1 # calcium in amplitude
kin0=10e-3 # calcium start time
kin1=kin0+3e-3 # calcium duration
kdt=50e-3 # time between bursts from vertical rises of calcium

nbursts=2 # number of calcium spikes

edt=10e-3 # extra looking time past the end of the last calcium spike
tmax=nbursts*kdt+edt
dt=1e-4
runtime=int(tmax/dt)

kin=np.zeros(runtime)
for i in range(nbursts):
    kin[int((kin0+i*kdt)/dt):int((kin1+i*kdt)/dt)]=kinbar



Caf=np.zeros(runtime)
