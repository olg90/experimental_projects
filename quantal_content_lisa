from numpy import exp
from numpy import sqrt as Sqrt
from numpy import log as Log

def sim(ninit, nuinit, pr, M, kin, kd, tauc, ca, c, cb, delta_t, aptimerinit, naps, navgs):
    
    navs=[]
    bavs=[]
    
    for _ in range(navgs):
    
        nlist=[]
        nulist=[]
        blist=[]
        calist=[]
        tlist=[]
        prelist=[]
        
        n=ninit
        nu=nuinit
        tcurr=0
        timer = delta_t
        bnum=0
        e=1e-6
        apcount=0
        aptimer=aptimerinit
        while apcount<naps:
            t0=exponential(1/(kin+e))
            t1=exponential(1/(kd*nu*(M-n)+e))
            t2=aptimer
            t3 = timer
    
            if t0 < t1 and t0 < t2 and t0<t3: 
                nu+=1
                tmin=t0
                aptimer-=tmin
                timer-=tmin

            elif t1<t0 and t1<t2 and t1<t3: # add a docked vesicle
                nu-=1
                n+=1
                tmin = t1
                timer-=tmin
                aptimer-=tmin
                
            if t2 < t0 and t2 < t1 and t2<t3: # AP occurrs
                ca+=c
                b = binomial(n, pr(ca))
                n-=b
                blist.append(b)
                apcount+=1
                
                tmin = t2
                timer-=tmin
                aptimer=aptimerinit
                prelist.append(tcurr+tmin)
                bnum+=1
    
            else:
                tmin=t3
                timer = delta_t
                aptimer-=tmin
                nlist.append(n)
                nulist.append(nu)
                tlist.append(tcurr)
                calist.append(ca)
                    
            tcurr += tmin
            # Update the calcium dynamics
            ca += -(ca-cb)/tauc*tmin
        bavs.append(blist)
        
            
    minlen = np.min([len(x) for x in bavs])
    bavs = np.array([x[:minlen] for x in bavs])
    bavs=np.mean(bavs, axis=0)
    
    return tlist, nlist, nulist, bavs, prelist, calist

