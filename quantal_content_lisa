def sim(ninit, nuinit, pr, taup, M, kin, kd, tauc, ca, c, cb, 
        delta_t, aptimerinit, naps, navgs):

    bavs=[]

    for _ in range(navgs):

        nlist=[]
        nulist=[]
        blist=[]
        calist=[]
        tlist=[]
        prelist=[]

        n=ninit
        nu=nuinit
        tcurr=0
        timer = delta_t
        apcount=0
        aptimer=aptimerinit
        e=1e-6

        while apcount<naps:

            t0=exponential(1/(kin+e))
            t1=exponential(1/(kd*nu*(M-n)+e))
            t2=aptimer
            t3=timer

            if t0<t1 and t0<t2 and t0<t3:
                nu+=1
                tmin=t0
                aptimer-=tmin
                timer-=tmin

            elif t1<t0 and t1<t2 and t1<t3:
                nu-=1
                n+=1
                tmin=t1
                aptimer-=tmin
                timer-=tmin

            if t2<t0 and t2<t1 and t2<t3:
                ca+=c
                b=binomial(n,pr(ca, cb, taup))
