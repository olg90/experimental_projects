# =========================
# PERMUTATION TEST (FIXED)
# =========================

def perm_test(x, y, n_perm=5000):

    x = np.asarray(x)
    y = np.asarray(y)

    obs = np.mean(x) - np.mean(y)

    pooled = np.concatenate([x, y])
    n = len(x)

    count = 0

    for _ in range(n_perm):

        perm = np.random.permutation(pooled)

        x_p = perm[:n]
        y_p = perm[n:]

        stat = np.mean(x_p) - np.mean(y_p)

        if abs(stat) >= abs(obs):
            count += 1

    return count / n_perm


