            last_low = np.zeros(n_time)
            last_high = np.zeros(n_time)

            for t in range(n_time):

                m, lo, hi = bootstrap_mean_ci(first5[t, :])
                first_mean[t], first_low[t], first_high[t] = m, lo, hi
                pbar.update(1)

                m, lo, hi = bootstrap_mean_ci(last5[t, :])
                last_mean[t], last_low[t], last_high[t] = m, lo, hi
                pbar.update(1)

            dataset_results.append({
                "first_mean": first_mean,
                "first_low": first_low,
                "first_high": first_high,
                "last_mean": last_mean,
                "last_low": last_low,
                "last_high": last_high,
            })

        results.append(dataset_results)

#%%

# =========================
# GLOBAL STYLE CONTROLS
# =========================
a1 = 1#0.3   # alpha for first 5 repeats
a2 = 1#0.3   # alpha for last 5 repeats

for fnum, fname in enumerate(fnames):

