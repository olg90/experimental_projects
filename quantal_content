                   markeredgecolor='C0',
                   markersize=15,
                   linestyle='None')

        ax_tt.plot(t[sig_01], y2[sig_01], 's',
                   markerfacecolor='C1',
                   markeredgecolor='C1',
                   markersize=15,
                   linestyle='None')

        # 0.05 significant but not 0.01
        mid = sig_05 & ~sig_01

        ax_tt.plot(t[mid], y1[mid], 'o',
                   markerfacecolor='C0',
                   markeredgecolor='white',
                   markersize=12,
                   linestyle='None')

        ax_tt.plot(t[mid], y2[mid], 'o',
                   markerfacecolor='C1',
                   markeredgecolor='white',
                   markersize=12,
                   linestyle='None')

        # not significant
        ax_tt.plot(t[ns], y1[ns], 'o',
                   markerfacecolor='white',
                   markeredgecolor='C0',
                   markersize=6,
                   linestyle='None')

        ax_tt.plot(t[ns], y2[ns], 'o',
                   markerfacecolor='white',
                   markeredgecolor='C1',
                   markersize=6,
                   linestyle='None')

        # =========================
        # LEGEND
        # =========================

        legend_handles = [

            Line2D([0],[0], marker='s', linestyle='None',
                   markerfacecolor='C0', markeredgecolor='C0',
