            Line2D([0],[0], marker='o', linestyle='None',
                   markerfacecolor='white', markeredgecolor='C0',
                   markersize=8, label='First 5 (insignificant)'),

            Line2D([0],[0], marker='o', linestyle='None',
                   markerfacecolor='white', markeredgecolor='C1',
                   markersize=8, label='Last 5 (insignificant)'),

            Line2D([0],[0], marker='s', linestyle='None',
                   markerfacecolor='C1', markeredgecolor='C1',
                   markersize=15, label='Last 5 (p < 0.01)'),

            Line2D([0],[0], marker='o', linestyle='None',
                   markerfacecolor='C1', markeredgecolor='white',
                   markersize=12, label='Last 5 (0.01 ≤ p < 0.05)'),
        ]

        ax_tt.legend(
            handles=legend_handles,
            loc='center left',
            bbox_to_anchor=(1.02, 0.5),
            borderaxespad=0,
            fontsize=fs,
            title=f'Significant time points\np<0.05: {percent_sig:.1f}%\np<0.01: {percent_sig01:.1f}%',
            title_fontsize=fs
        )

        ax_tt.set_title('First 5 vs Last 5 (t-test)', fontsize=fs)
