import numpy as np
import pandas as pd
import os
import matplotlib.pyplot as plt

os.chdir(r'C:\Users\Oliver\Desktop\Research\quantal content')

file1 = '100Hz_1s_20_repeats_P11.xlsx'
file2 = '100Hz_1s_20_repeats_P38.xlsx'

fnames = ['P11', 'P38']

excel1 = pd.read_excel(file1, sheet_name=None, header=None)
excel2 = pd.read_excel(file2, sheet_name=None, header=None)

# full data (optional)
fulldata1 = np.array([df.to_numpy() for df in excel1.values()])

# time vector
times = fulldata1[0][1:, 0]

# stripped data
data1 = np.array([df.to_numpy()[1:, 1:] for df in excel1.values()])
data2 = np.array([df.to_numpy()[1:, 1:] for df in excel2.values()])

data = [data1, data2]

# =========================
# SETTINGS
# =========================
fnum = 0
dnum = 2

fig, ax = plt.subplots()
ax.set_title("Click a line or legend")
ax.set_xlabel("Time (sec)")
ax.set_ylabel("Quantal content")

lines = []
legend_map = {}

# =========================
# PLOT LINES
# =========================
for i in range(data[fnum][dnum].shape[1]):
    line, = ax.plot(
        times,
        data[fnum][dnum][:, i],
        linewidth=1,
        label=f"{i}",
        picker=5
    )
    lines.append(line)

# =========================
# LEGEND (clickable)
# =========================
legend = ax.legend()

for legline, origline in zip(legend.get_lines(), lines):
    legline.set_picker(True)
    legend_map[legline] = origline

# =========================
# HIGHLIGHT FUNCTION
# =========================
def highlight(line):
    for l in lines:
        l.set_linewidth(1)
        l.set_alpha(0.2)

    line.set_linewidth(3)
    line.set_alpha(1)

    ax.set_title(f"Selected line: {line.get_label()}")

    fig.canvas.draw()

# =========================
# CLICK HANDLER
# =========================
def on_pick(event):
    artist = event.artist

    # legend click
    if artist in legend_map:
        highlight(legend_map[artist])
        print("legend clicked:", legend_map[artist].get_label())
        return

    # line click
    if artist in lines:
        highlight(artist)
        print("line clicked:", artist.get_label())

fig.canvas.mpl_connect("pick_event", on_pick)

plt.show()
