def bootstrap_mean_ci(x, n_boot=10000):

    x = np.asarray(x, dtype=float)

    boots = np.empty(n_boot)

    for i in range(n_boot):

        sample = np.random.choice(
            x,
            size=len(x),
            replace=True
        )

        boots[i] = np.mean(sample)

    mean = np.mean(x)

    lower, upper = np.percentile(
        boots,
        [2.5, 97.5]
    )

    return mean, lower, upper

