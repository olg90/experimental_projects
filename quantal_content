fnames = ['P11', 'P38']

# =========================
# LOAD DATA
# =========================

excel1 = pd.read_excel(file1, sheet_name=None, header=None)
excel2 = pd.read_excel(file2, sheet_name=None, header=None)

data1 = np.array([df.to_numpy()[1:, 1:].astype(float) for df in excel1.values()])
data2 = np.array([df.to_numpy()[1:, 1:].astype(float) for df in excel2.values()])

data = [data1, data2]

times = excel1[list(excel1.keys())[0]].to_numpy()[1:, 0].astype(float)

# =========================
# PERMUTATION TEST (FIXED)
# =========================

def perm_test(x, y, n_perm=5000):

    x = np.asarray(x)
    y = np.asarray(y)

    obs = np.mean(x) - np.mean(y)

    pooled = np.concatenate([x, y])
    n = len(x)

    count = 0

    for _ in range(n_perm):

        perm = np.random.permutation(pooled)

        x_p = perm[:n]
        y_p = perm[n:]

        stat = np.mean(x_p) - np.mean(y_p)

        if abs(stat) >= abs(obs):
            count += 1

    return count / n_perm


# =========================
# ANALYSIS + PLOTTING
# =========================

alpha = 0.05

perm_results = []

for fnum, fname in enumerate(fnames):

    file_results = []

    for cell_idx, cell in enumerate(data[fnum]):

        first5 = cell[:, :5]
        last5  = cell[:, -5:]

        n_time = cell.shape[0]

        pvals = np.zeros(n_time)
        sig = np.zeros(n_time, dtype=bool)

        first_mean = np.mean(first5, axis=1)
        last_mean = np.mean(last5, axis=1)

        for t in tqdm(range(n_time), desc=f'perm {fname} cell {cell_idx+1}'):

            p = perm_test(first5[t, :], last5[t, :])

            pvals[t] = p
            sig[t] = p < alpha

        file_results.append({
            "pvals": pvals,
            "sig": sig,
            "first_mean": first_mean,
            "last_mean": last_mean
        })

    perm_results.append(file_results)

