data2 = np.array([df.to_numpy()[1:, 1:] for df in excel2.values()])

data = [data1, data2]

times = np.array(list(excel1.values())[0].to_numpy()[1:, 0])

# -----------------------------
# normalize each repeat by its first value
# then average repeats -> cell trace
# then average cells -> condition trace
# -----------------------------

norm_cells = []

for fnum in [0, 1]:  # P11, P38
    cell_traces = []

    for dnum in range(data[fnum].shape[0]):  # cells
        cell = data[fnum][dnum]  # time x repeats

        norm_repeats = np.zeros_like(cell, dtype=float)

        for r in range(cell.shape[1]):
            trace = cell[:, r]
            base = trace[0]

            if base != 0:
                norm_repeats[:, r] = trace / base
            else:
                norm_repeats[:, r] = trace

        # average across repeats (within cell)
        cell_mean = np.mean(norm_repeats, axis=1)

        cell_traces.append(cell_mean)

    norm_cells.append(np.array(cell_traces))

# -----------------------------
# average across cells ONLY (no SEM, no std)
