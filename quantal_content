import numpy as np
from tqdm import tqdm

def perm_test(x, y, n_perm=5000):

    x = np.asarray(x)
    y = np.asarray(y)

    obs = np.mean(x) - np.mean(y)

    pooled = np.concatenate([x, y])
    n = len(x)

    count = 0

    for _ in range(n_perm):

        perm = np.random.permutation(pooled)

        x_p = perm[:n]
        y_p = perm[n:]

        stat = np.mean(x_p) - np.mean(y_p)

        if abs(stat) >= abs(obs):
            count += 1

    return count / n_perm


n_boot = 10000
rng = np.random.default_rng(0)

alpha = 0.05

n_cells = len(data3)
n_tests = len(data3[0])

total_jobs = n_cells * n_tests
job = 0

results = [[None for _ in range(n_tests)] for _ in range(n_cells)]

for cell in range(n_cells):

    for test in range(n_tests):

        job += 1

        X = np.asarray(data3[cell][test], dtype=float)

        n_time, n_repeats = X.shape

        # ==================================================
        # MEAN + BOOTSTRAP CI
        # ==================================================

        mean_trace = np.nanmean(X, axis=1)

        boot_means = np.empty((n_boot, n_time))

        for b in range(n_boot):

            idx = rng.integers(0, n_repeats, n_repeats)

            boot_means[b] = np.nanmean(
                X[:, idx],
                axis=1
            )

        mean_lo = np.percentile(
            boot_means,
            2.5,
            axis=0
        )

        mean_hi = np.percentile(
            boot_means,
            97.5,
            axis=0
        )

        # ==================================================
        # NORMALIZED
        # ==================================================

        normX = X / X[0:1, :]

        norm_mean = np.nanmean(
            normX,
            axis=1
        )

        # ==================================================
        # FANO
        # ==================================================

        fano = (
            np.nanvar(X, axis=1, ddof=1)
            /
            np.nanmean(X, axis=1)
        )

        boot_fano = np.empty(
            (n_boot, n_time)
        )

        for b in range(n_boot):

            idx = rng.integers(
                0,
                n_repeats,
                n_repeats
            )

            Xb = X[:, idx]

            m = np.nanmean(
                Xb,
                axis=1
            )

            v = np.nanvar(
                Xb,
                axis=1,
                ddof=1
            )

            boot_fano[b] = v / m

        fano_lo = np.percentile(
            boot_fano,
            2.5,
            axis=0
        )

        fano_hi = np.percentile(
