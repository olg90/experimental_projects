        y1 = r["first_mean"]
        y1_low = r["first_low"]
        y1_high = r["first_high"]
        yerr1 = np.vstack([y1 - y1_low, y1_high - y1])

        # -------------------
        # Last 5 repeats
        # -------------------
        y2 = r["last_mean"]
        y2_low = r["last_low"]
        y2_high = r["last_high"]
        yerr2 = np.vstack([y2 - y2_low, y2_high - y2])

        # -------------------
        # OVERLAP DETECTION
        # -------------------
        overlap_low = np.maximum(y1_low, y2_low)
        overlap_high = np.minimum(y1_high, y2_high)
        overlap_mask = overlap_high >= overlap_low

        if np.any(overlap_mask):
            overlap_center = 0.5 * (overlap_low + overlap_high)
            overlap_percent = 100 * np.mean(overlap_mask)
        else:
            overlap_center = None
            overlap_percent = 0.0

        # -------------------
        # PLOTS (NO CONNECTING LINES)
        # -------------------
        ax.errorbar(
