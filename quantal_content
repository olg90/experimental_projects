#%% Calculate bootstrapping

mbounds=[]
ffbounds=[]
for k, datax in enumerate(data):
    mboundsdata=[]
    ffboundsdata=[]
    for j, ds in enumerate(datax):
        mboundsx=[]
        ffboundsx=[]
        for i, row in enumerate(ds):
            print(k, len(data), j, len(datax), i, len(ds))
            _, mbound = bootstrap(row, np.mean)
            _, ffbound = bootstrap(row, get_FF)
            mboundsx.append(mbound)
            ffboundsx.append(ffbound)
        mboundsdata.append(mboundsx)
        ffboundsdata.append(ffboundsx)
    mbounds.append(mboundsdata)
    ffbounds.append(ffboundsdata)
    

means=[]
ffs=[]
for k, datax in enumerate(data):
    meandata=[]
    ffdata=[]
    for j, ds in enumerate(datax):
        meanx=[]
        ffx=[]
        for i, row in enumerate(ds):
            print(k, len(data), j, len(datax), i, len(ds))
            meanx.append(np.mean(row))
            ffx.append(np.var(row)/np.mean(row))
        meandata.append(meanx)
        ffdata.append(ffx)
    means.append(meandata)
    ffs.append(ffdata)


mbounds = np.array(mbounds, dtype=object)
