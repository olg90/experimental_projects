import numpy as np
import pandas as pd
import os
import matplotlib.pyplot as plt
from scipy.stats import gamma

os.chdir(r'C:\Users\Oliver\Desktop\Research\quantal content')
file1 = '100Hz_1s_20_repeats_P11.xlsx'
file2 = '100Hz_1s_20_repeats_P38.xlsx'
excel1 = pd.read_excel(file1, sheet_name=None, header=None)
excel2 = pd.read_excel(file2, sheet_name=None, header=None)
data1 = np.array([df.to_numpy()[1:, 1:] for df in excel1.values()])
data2 = np.array([df.to_numpy()[1:, 1:] for df in excel2.values()])
data = np.array([data1, data2],dtype=object)
times = np.array(list(excel1.values())[0].to_numpy()[1:, 0])


pr=0.85
# pr2=0.845019495915803
pr2=pr
pr3=0

M2=30.1224080550994
M1=np.mean(data[1][2], axis=1)[0]/pr-M2
M3=0

nstim=100

hill=1.02582448684247
thr=1.530469326
prefill=0.777994143267587
prefillmin=0
CVq=0.2

p1d=np.array([prefillmin+(prefill-prefillmin)/(1+((i)/thr)**hill) 
              for i in range(nstim)])
p1i=np.zeros(nstim)
p1i[0]=1#initially docked

p2i=np.zeros(nstim)
p2i[0]=1#initially docked
p2d=0.777994143277144*np.ones(nstim)#fixed probability of empty being refilled between i and i+1 AP

p3i=np.zeros(nstim)
p3i[0]=1
p3d=np.zeros(nstim)

for i in range(1,nstim):
    p1i[i]=p1i[i-1]*(1-pr)+(1-p1i[i-1]*(1-pr))*p1d[i-1]
    p2i[i]=p2i[i-1]*(1-pr2)+(1-p2i[i-1]*(1-pr2))*p2d[i-1]
    p3i[i]=p3i[i-1]*(1-pr3)+(1-p3i[i-1]*(1-pr3))*p3d[i-1] 

mqc=M1*p1i*pr + M2*p2i*pr2 + M3*p3i*pr3
vqc=M1*p1i*pr*(1-p1i*pr) + M2*p2i*pr2*(1-p2i*pr2) + M3*p3i*pr3*(1-p3i*pr3)
vei=mqc*CVq**2+vqc
CV2ei=vei/mqc**2
ffei=vei/mqc

