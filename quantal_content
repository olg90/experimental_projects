import numpy as np
from tqdm import tqdm
from scipy.stats import ttest_ind

n_boot = 10000
rng = np.random.default_rng(0)

n_cells = len(data3)
n_tests = len(data3[0])

total_jobs = n_cells * n_tests
job = 0

results = [[None for _ in range(n_tests)] for _ in range(n_cells)]

for cell in range(n_cells):

    for test in range(n_tests):

        job += 1

        X = np.asarray(data3[cell][test], dtype=float)

        n_time, n_repeats = X.shape

        # ==================================================
        # MEAN + BOOTSTRAP CI
        # ==================================================

        mean_trace = np.nanmean(X, axis=1)

        boot_means = np.empty((n_boot, n_time))

        for b in range(n_boot):

            idx = rng.integers(0, n_repeats, n_repeats)

            boot_means[b] = np.nanmean(
                X[:, idx],
                axis=1
            )

        mean_lo = np.percentile(boot_means, 2.5, axis=0)
        mean_hi = np.percentile(boot_means, 97.5, axis=0)

        # ==================================================
        # NORMALIZED
        # ==================================================

        normX = X / X[0:1, :]

        norm_mean = np.nanmean(normX, axis=1)

        # ==================================================
        # FANO
        # ==================================================

        fano = (
            np.nanvar(X, axis=1, ddof=1)
            / np.nanmean(X, axis=1)
        )

        boot_fano = np.empty((n_boot, n_time))

        for b in range(n_boot):

            idx = rng.integers(0, n_repeats, n_repeats)

            Xb = X[:, idx]

            m = np.nanmean(Xb, axis=1)
            v = np.nanvar(Xb, axis=1, ddof=1)

            boot_fano[b] = v / m

        fano_lo = np.percentile(boot_fano, 2.5, axis=0)
        fano_hi = np.percentile(boot_fano, 97.5, axis=0)

        # ==================================================
        # FIRST 5 vs LAST 5 (t-test)
        # ==================================================

        first5 = X[:, :5]
        last5  = X[:, -5:]

        pvals = np.zeros(n_time)
        sig = np.zeros(n_time, dtype=bool)
        sig_hard = np.zeros(n_time, dtype=bool)

        first_mean = np.mean(first5, axis=1)
        last_mean = np.mean(last5, axis=1)

        for tt in range(n_time):

            x = first5[tt, :]
            y = last5[tt, :]

            _, p = ttest_ind(x, y, equal_var=False, nan_policy='omit')

            pvals[tt] = p
            sig[tt] = p < 0.05
            sig_hard[tt] = p < 0.01

        print(f'{100*job/total_jobs:.1f}% ({job}/{total_jobs})')

        results[cell][test] = {

            'raw': X,

            'mean': mean_trace,
            'mean_lo': mean_lo,
            'mean_hi': mean_hi,

            'norm': normX,
            'norm_mean': norm_mean,

            'fano': fano,
            'fano_lo': fano_lo,
            'fano_hi': fano_hi,

            'ttest_pvals': pvals,
            'ttest_sig': sig,
            'ttest_sig_hard': sig_hard,

            'ttest_first_mean': first_mean,
            'ttest_last_mean': last_mean
        }
        
