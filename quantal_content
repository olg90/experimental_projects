def get_pi_occupied(pi, pr, pd):
    return pi*(1-pr)+(1-pi*(1-pr))*pd

def bootstrap(data, metric, n_bootstraps=1000, percentiles=(2.5, 97.5)):
    data = np.asarray(data)
    n = len(data)
    vals = [
        metric(np.random.choice(data, size=n, replace=True))
        for _ in range(n_bootstraps)
    ]
    return metric(data), np.percentile(vals, percentiles)

def get_FF(x):
    return np.var(x)/np.mean(x)

