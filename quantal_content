    artist = event.artist

    # if click came from legend
    if artist in legend_entries:
        highlight(legend_entries[artist])
        print("legend clicked:", legend_entries[artist].get_label())
        return

    # if click came from line
    if artist in lines:
        highlight(artist)
        print("line clicked:", artist.get_label())


fig.canvas.mpl_connect('pick_event', on_pick)

plt.show()

