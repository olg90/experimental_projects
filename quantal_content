#%% plot all traces with large deviation from window average

import numpy as np
import matplotlib.pyplot as plt

t = np.asarray(times, dtype=float)
window = 10

for fnum in range(len(data)):

    for dnum in range(len(data[fnum])):

        ds = np.asarray(data[fnum][dnum], dtype=float)

        for run in range(ds.shape[1]):

            trace = ds[:, run]

            # =============================================
            # causal expanding / sliding window average
            # =============================================
            cumsum = np.cumsum(trace, dtype=float)
            window_avg = np.empty_like(trace, dtype=float)

            for i in range(len(trace)):
                start = max(0, i - window + 1)

                total = cumsum[i] - (cumsum[start - 1] if start > 0 else 0.0)
                window_avg[i] = total / (i - start + 1)

            # =============================================
            # deviation criterion
            # =============================================
            eps = 1e-6

            frac_dev = np.abs(trace - window_avg) / (np.abs(window_avg) + eps)

            # =============================================
            # plot if ANY point > 100% away
            # =============================================
            if np.any(frac_dev > 1.0):

                plt.figure(figsize=(7, 5))

                plt.plot(t, trace, linewidth=1, label='trace')

                plt.plot(t, window_avg, linestyle='--', linewidth=1, label='window avg')

                plt.title(f'{fnames[fnum]} cell {dnum+1} repeat {run+1}')
                plt.xlabel('Time (sec)')
                plt.ylabel('Quantal content')

                plt.legend()

plt.show()

