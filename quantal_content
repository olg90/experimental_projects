            capsize=3,
            linewidth=1,
            markersize=3,
            alpha=a1,
            label='First 5'
        )

        ax.errorbar(
            times, y2, yerr=yerr2,
            fmt='s',              # no line
            capsize=3,
            linewidth=1,
            markersize=3,
            alpha=a2,
            label='Last 5'
        )

        if np.any(overlap_mask):
