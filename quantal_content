    df.to_numpy()[1:, 1:].astype(float)
    for df in excel2.values()
])

data = [data1, data2]

# =============================================================================
# Bootstrap
# =============================================================================

def bootstrap_mean_ci(x, n_boot=10000):

    x = np.asarray(x, dtype=float)

    boots = np.empty(n_boot)

    for i in range(n_boot):

        sample = np.random.choice(
            x,
            size=len(x),
            replace=True
        )

        boots[i] = np.mean(sample)

    mean = np.mean(x)

    lower, upper = np.percentile(
        boots,
        [2.5, 97.5]
    )

    return mean, lower, upper

# =============================================================================
# Progress count
# =============================================================================

total_operations = sum(cell.shape[0] * 2 for dataset in data for cell in dataset)

results = []

print(f'Total bootstrap calculations: {total_operations}')

with tqdm(total=total_operations, desc='Overall Progress', unit='bootstrap') as pbar:

    for dataset_idx, dataset in enumerate(data):

        dataset_results = []

        for cell_idx, cell in enumerate(dataset):

            print(f'\nProcessing {fnames[dataset_idx]} Cell {cell_idx + 1}/{len(dataset)}')

