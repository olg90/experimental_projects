#%% plot all traces with 200% increase from mean running average

t = np.asarray(times, dtype=float)

for fnum in range(len(data)):

    for dnum in range(len(data[fnum])):

        ds = np.asarray(data[fnum][dnum], dtype=float)

        for run in range(ds.shape[1]):

            trace = ds[:, run]

            # =================================================
            # running average
            # =================================================
            running_avg = (
                np.cumsum(trace)
                / np.arange(1, len(trace) + 1)
            )

            # =================================================
            # relative deviation from running average
            # =================================================
            eps = 1e-12

            frac_dev = (
                np.abs(trace - running_avg)
                / (np.abs(running_avg) + eps)
            )

            # =================================================
            # only plot if any point deviates > 200%
            # =================================================
            if np.any(frac_dev > 1.0):

                plt.figure(figsize=(7, 5))

                plt.plot(
                    t,
                    trace,
                    linewidth=1
                )

                plt.plot(
                    t,
                    running_avg,
                    linestyle='--',
                    linewidth=1
                )

                plt.title(
                    f'{fnames[fnum]} cell {dnum+1} repeat {run+1}'
                )

                plt.xlabel('Time (sec)')
                plt.ylabel('Quantal content')

