W[PYR2, PYR1] = 2.0
W[PYR2, FB1 ] = 2.0
W[PYR2, FB2 ] = 2.0

# FB1 inhibits
W[FB1, PYR2] = -2.0
W[FB1, FB2 ] = -2.0

# FB2 inhibits
W[FB2, PYR1] = -2.0
W[FB2, PYR2] = -2.0
W[FB2, FB1 ] = -2.0

# FF1 inhibits
W[FF1, PYR1] = -2.0
W[FF1, PYR2] = -2.0
W[FF1, FF2 ] = -2.0

# FF2 inhibits
W[FF2, PYR1] = -2.0
W[FF2, PYR2] = -2.0
W[FF2, FF1 ] = -2.0

# =====================================
# External input
# =====================================
Iext = np.zeros((N, len(time)))

pulse = np.zeros(len(time))

