    Iext = np.zeros((N, len(time)))
    Iext[PYR1] = I_pyr1
    Iext[PYR2] = I_pyr2
    Iext[FF1]  = I_ff1
    Iext[FF2]  = I_ff2

    # =====================================
    # Network simulation
    # =====================================
    V = np.zeros((N, len(time)))
    vth = np.zeros((N, len(time)))
    spikes = np.zeros((N, len(time)))

    for i in range(N):
        V[i, 0] = V0[i]
        vth[i, 0] = vt[i]

    rfon = np.zeros(N, dtype=bool)
    rftimer = np.ones(N) * np.inf

    for t in range(1, len(time)):

        for post in range(N):

            Isyn = np.sum(W[:, post] * spikes[:, t-1])
            I = Iext[post, t-1] + Isyn

            i_ion = gL[post] * (V[post, t-1] - V0[post])
            dVdt = (I - i_ion) / C_m[post]

            V[post, t] = V[post, t-1] + dt * dVdt * (1 - rfon[post])

            dvthdt = -(vth[post, t-1] - vt[post]) / tauvth[post]
            vth[post, t] = vth[post, t-1] + dt * dvthdt

            if rftimer[post] != np.inf:
                rftimer[post] -= dt
            if rftimer[post] <= 0:
                rftimer[post] = np.inf
                rfon[post] = False

            if V[post, t] > vth[post, t]:

                spikes[post, t] = 1
                rfon[post] = True
                rftimer[post] = rf

                vth[post, t] += (
                    alpha[post][0]
                    + alpha[post][1] * (V[post, t] / vt[post])
                    + alpha[post][2] * (V[post, t] / vt[post])**2
                )

