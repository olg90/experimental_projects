    # =====================================
    # firing rate extraction
    # =====================================
    for neuron in range(N):
        spike_times = time[spikes[neuron] == 1]

        if len(spike_times) >= 2:
            isi = np.diff(spike_times)
            output_rates[neuron, k] = 1 / np.mean(isi)
