gL  = [1/(50e6), 1/(50.29e6), 1/(120e6)]
vt  = [-77e-3, -62e-3, -70e-3]
tauvth = [7e-3, 1e-3, 1e-3]

alpha = [
    [75e-3, 0e-3, 0e-3],
    [1e-3, 1e-3, 1e-3],
