for n in range(N):
    tp = celltype[n]
    V[n, 0] = V0[tp]
    Vth_net[n, 0] = vt[tp]

# =====================================
# Synapses (double exponential)
# =====================================
tau_r = 1e-3
tau_d = 10e-3

xr = np.zeros((N, N))
xd = np.zeros((N, N))

# =====================================
# Simulation
# =====================================
for t in range(1, len(time)):

    xr += dt * (-xr / tau_r)
    xd += dt * (-xd / tau_d)

    g = xd - xr

    for post in range(N):

        tp = celltype[post]

        Isyn = np.sum(W[:, post] * g[:, post])

        I_total = Iext[post, t-1] + Isyn

        i_ion = gL[tp] * (V[post, t-1] - V0[tp])

        dVdt = (I_total - i_ion) / C_m[tp]

