W[PYR2, FB1 ] = 1e-9
W[PYR2, FB2 ] = 1e-9

W[FB1, PYR2] = -1*0
W[FB1, FB2 ] = -1*0

W[FB2, PYR1] = -1*0
W[FB2, PYR2] = -1*0
W[FB2, FB1 ] = -1*0

W[FF1, PYR1] = -1*0
W[FF1, PYR2] = -1*0
W[FF1, FF2 ] = -1*0

W[FF2, PYR1] = -1*0
W[FF2, PYR2] = -1*0
W[FF2, FF1 ] = -1*0

