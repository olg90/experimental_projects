# State variables
# =====================================
V = np.zeros((N, len(time)))
spikes = np.zeros((N, len(time)))

# Synaptic state variables
xr = np.zeros((N, N))
xd = np.zeros((N, N))

# =====================================
# Simulation
# =====================================
for t in range(1, len(time)):

    # Decay synapses
    xr += dt * (-xr / tau_r)
    xd += dt * (-xd / tau_d)

