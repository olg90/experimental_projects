# =====================================
# Simulation parameters
# =====================================
dt = 0.01
T = 1000
time = np.arange(0, T, dt)

tau_m = 20.0
Vth = 1.0
Vreset = 0.0

# Synaptic rise and decay times
tau_r = 2.0
tau_d = 10.0

# =====================================
# Neuron indices
# =====================================
PYR1 = 0
PYR2 = 1
FB1  = 2
FB2  = 3
FF1  = 4
FF2  = 5

names = ["PYR1", "PYR2", "FB1", "FB2", "FF1", "FF2"]

N = 6

# =====================================
# Weight matrix
# W[pre, post]
# =====================================
W = np.zeros((N, N))

# PYR1 excites
W[PYR1, PYR2] = 2.0
W[PYR1, FB1 ] = 2.0
W[PYR1, FB2 ] = 2.0

# PYR2 excites
W[PYR2, PYR1] = 2.0
W[PYR2, FB1 ] = 2.0
W[PYR2, FB2 ] = 2.0

# FB1 inhibits
W[FB1, PYR2] = -2.0
W[FB1, FB2 ] = -2.0

# FB2 inhibits
W[FB2, PYR1] = -2.0
W[FB2, PYR2] = -2.0
W[FB2, FB1 ] = -2.0

# FF1 inhibits
W[FF1, PYR1] = -2.0
W[FF1, PYR2] = -2.0
W[FF1, FF2 ] = -2.0

# FF2 inhibits
W[FF2, PYR1] = -2.0
W[FF2, PYR2] = -2.0
W[FF2, FF1 ] = -2.0

# =====================================
# External input
# =====================================
Iext = np.zeros((N, len(time)))

pulse = np.zeros(len(time))

tstart=100
tend=800
pulse[(time >= tstart) & (time < tend)] = 4.5

# Input excites PYR1, PYR2, FF1, FF2
Iext[PYR1] = pulse
Iext[PYR2] = pulse
Iext[FF1 ] = pulse
Iext[FF2 ] = pulse

